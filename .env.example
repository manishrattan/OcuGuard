# OcuGuard AI Enterprise Configuration

# Server configurations
PORT=5000

# Optional API Key authentication protection for system endpoints (/v1/system/config, /v1/system/stats)
# If left empty, no key checks will be enforced
API_KEY=your_optional_secret_api_key_here

# OpenAI credential keys for LangChain agent routing
# If left empty, agents will automatically run zero-dependency local math fallbacks
OPENAI_API_KEY=your_openai_api_key_here
